# Where signup notifications should be sent.
NEWSLETTER_TO_EMAIL=bookings@sunbellamusic.com

# Preferred path: SendGrid using an already verified sender/domain.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=hello@zenfulkayla.com
SENDGRID_FROM_NAME=Sunbrella

# Optional: add subscribers to a SendGrid Marketing Contacts list too.
# Leave blank if you only want email notifications.
SENDGRID_CONTACT_LIST_ID=

# Fallback path: Resend, only used if SendGrid env vars are absent.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
NEWSLETTER_FROM_EMAIL=Sunbrella <newsletter@sunbellamusic.com>
